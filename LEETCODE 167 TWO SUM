class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        l=0
        r=len(nums)-1
        while l<r:
            b= nums[l] + nums[r]
            if b==target:
                return [l+1,r+1]
            elif b<target:
                l=l+1
            else:
                r=r-1
        
